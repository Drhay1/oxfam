<div id="rates" style="background-color: @(Brain.CurrentTheme.RatesBackgroundColor)" class="content shaded">
    <div class="container">

        <div class="row">
            <div class="col-12 text-center">
                <h3>Our Rates?</h3>
            </div>
        </div>

        <div class="row">
            <div class="col-md-4 rate-card">
                <h5>@Brain.Rates[0].Title</h5>
                <h1>@Brain.Rates[0].Text</h1>
                <Anchor class="rate-link">Details ></Anchor>
            </div>

            <div class="col-md-4 rate-card">
                <h5>@Brain.Rates[1].Title</h5>
                <h1>@Brain.Rates[1].Text</h1>
                <Anchor class="rate-link">Details ></Anchor>
            </div>

            <div class="col-md-4 rate-card">
                <h5>@Brain.Rates[2].Title</h5>
                <h1>@Brain.Rates[2].Text</h1>
                <Anchor class="rate-link">Details ></Anchor>
            </div>
        </div>

    </div>
</div>