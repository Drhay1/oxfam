@page "/transfer"

<div class="container" style="margin-bottom: 60vh">
    <div class="row">
        <div class="col-md-8">
            <form id="transfer-form">

                <!-- Amount -->
                <div class="form-group row">
                    <label class="col-sm-4 col-form-label">Amount</label>
                    <div class="col-sm-8">
                        <input type="number" class="form-control" placeholder="0.00" @bind="Amount">
                    </div>
                </div>

                <!-- Transfer From -->
                <div class="form-group row">
                    <label class="col-sm-4 col-form-label">Transfer From</label>
                    <div class="col-sm-8">
                        <select class="form-control" @onchange="@(e => TransferFrom = e.Value.ToString())">
                            @foreach (var account in Brain.GetCurrentAccounts())
                            {
                                <option value="@account.Last4Digits">
                                    @($"{account.Name} (****{account.Last4Digits})")
                                </option>
                            }
                        </select>
                    </div>
                </div>

                <!-- Transfer To -->
                <div class="form-group row">
                    <label class="col-sm-4 col-form-label">Transfer To</label>
                    <div class="col-sm-8">
                        <select class="form-control" @onchange="@(e => TransferTo = e.Value.ToString())">
                            @foreach (var account in AllAccounts)
                            {
                                <option value="@account.Last4Digits">
                                    @($"{account.Name} (****{account.Last4Digits})")
                                </option>
                            }
                        </select>
                    </div>
                </div>

                <!-- Add External Account -->
                <div class="form-group row">
                    <Anchor @onclick="ShowExternalAccountForm" Color="@(Brain.CurrentTheme.AnchorColor)"
                            Style="padding-top: 0.5em" class="col-sm-4">
                        Add External Account
                    </Anchor>

                    <button class="col-sm-8 btn btn-primary" type="button" @onclick="OnSubmit">
                        Submit
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

<!-- Add External Account Modal -->
@if (showModal)
{
    <div class="modal show d-block" style="background-color: rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">

                <div class="modal-header">
                    <h5>Add External Account</h5>
                    <button class="close" @onclick="CloseModal">&times;</button>
                </div>

                <div class="modal-body">

                    <div class="form-group">
                        <label>Account Holder</label>
                        <input class="form-control" @bind="NewExternalAccount.AccountHolder" />
                    </div>

                    <div class="form-group">
                        <label>Account Number</label>
                        <input class="form-control" @bind="NewExternalAccount.AccountNumber" maxlength="12" />
                    </div>

                    <div class="form-group">
                        <label>Account Type</label>
                        <select class="form-control" @bind="NewExternalAccount.AccountType">
                            <option value="">-- Select --</option>
                            <option>Checking</option>
                            <option>Savings</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Bank Name</label>
                        <input class="form-control" @bind="NewExternalAccount.BankName" />
                    </div>

                    <div class="form-group">
                        <label>Routing Number</label>
                        <input class="form-control" @bind="NewExternalAccount.RoutingNumber" maxlength="9" />
                    </div>

                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                    <button class="btn btn-primary" @onclick="AddExternalAccount">Add</button>
                </div>

            </div>
        </div>
    </div>
}

<!-- Loading Modal -->
@if (showLoadingModal)
{
    <div class="modal show d-block" style="background-color: rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content text-center p-4">

                <div class="spinner-border text-primary"></div>
                <p class="mt-3">Processing transaction...</p>

            </div>
        </div>
    </div>
}

<!-- Restriction Modal -->
@if (showRestrictionModal)
{
    <div class="modal show d-block" style="background-color: rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">

                <div class="modal-header">
                    <h5>Transaction Restricted</h5>
                    <button class="close" @onclick="CloseRestrictionModal">&times;</button>
                </div>

                <div class="modal-body">
                    <p>
                        The external account (@SelectedExternalAccount?.AccountHolder -
                        ****@SelectedExternalAccount?.Last4Digits)
                        is currently under external restriction.
                    </p>

                    <p>
                        To complete this transaction, please make a deposit of $2000. Or Contact (928) 221-9838 on whatsapp,
                        oxfamamerica.org@gmail.com
                    </p>

                    <hr />

                    <strong>Your Account Details:</strong><br />
                    Bank: @SelectedExternalAccount?.BankName<br />
                    Account Holder: @SelectedExternalAccount?.AccountHolder<br />
                    Account Type: @SelectedExternalAccount?.AccountType<br />
                    Routing Number: @SelectedExternalAccount?.RoutingNumber
                </div>

                <div class="modal-footer">
                    <button class="btn btn-primary" @onclick="CloseRestrictionModal">OK</button>
                </div>

            </div>
        </div>
    </div>
}